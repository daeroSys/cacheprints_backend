# ─────────────────────────────────────────────────────────────
#  CachePrint's IMS Backend — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/cacheprints_ims
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/cacheprints_ims
MONGODB_URI=mongodb://localhost:27017/cacheprints_ims

# Database name
DB_NAME=cacheprints_ims

# JWT secret key — change this to any long random string in production
JWT_SECRET=cacheprints_super_secret_jwt_key_2025

# JWT expiry (7 days)
JWT_EXPIRES_IN=7d

# Port the backend server runs on
PORT=5000

# Frontend URL for CORS (your Vite dev server)
CLIENT_URL=http://localhost:5173
